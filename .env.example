GEMINI_API_KEY=

# Raindrop.io ingest.
# For personal use, create a Raindrop app and copy its Test token.
RAINDROP_ACCESS_TOKEN=
RAINDROP_COLLECTION_ID=0
RAINDROP_SEARCH=
RAINDROP_FETCH_LIMIT=10

# Reader progress sync.
# Use a Neon Postgres database provisioned from the Vercel Marketplace.
DATABASE_URL=

# Google OAuth web client credentials.
# Authorized redirect URI for production:
# https://learning-machine.vercel.app/api/auth/callback/google
# Authorized redirect URI for local dev:
# http://localhost:8080/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional comma-separated allowlist. Leave empty to let any Google account
# sign in and keep its own private read-progress rows.
READER_ALLOWED_EMAILS=
